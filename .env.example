# SiliconFlow (硅基流动) API 配置
# 注册地址: https://siliconflow.cn
# 多个 Key 用逗号分隔，系统会随机选择使用
SILICONFLOW_API_KEYS=your_api_key_1,your_api_key_2,your_api_key_3
SILICONFLOW_API_URL=https://api.siliconflow.cn/v1/chat/completions
SILICONFLOW_VISION_MODEL=zai-org/GLM-4.6V

# 应用配置
DEBUG=true
SECRET_KEY=your-secret-key-here
